# Code Commit GitHub Extension - Environment Variables

# =============================================================================
# Required: GitHub Configuration
# =============================================================================

# GitHub Personal Access Token (repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Webhook secret (generate: openssl rand -hex 32)
GITHUB_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Optional: AI API Keys
# =============================================================================

# OpenAI API Key
OPENAI_API_KEY=

# Anthropic API Key (for Claude)
ANTHROPIC_API_KEY=

# =============================================================================
# Optional: Code Commit Settings
# =============================================================================

# Repository to apply fixes to
CODE_COMMIT_REPO_URL=https://github.com/your-org/your-repo

# Auto-merge PRs when checks pass
AUTO_MERGE_ENABLED=true

# Cloud Code Review service URL
CODE_REVIEW_URL=https://code-review.example.com

# =============================================================================
# Database (defaults work for docker-compose)
# =============================================================================

POSTGRES_USER=codecommit
POSTGRES_PASSWORD=codecommit
POSTGRES_DB=codecommit

REDIS_PASSWORD=your_redis_password